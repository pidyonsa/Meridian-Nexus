rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function temporaryAccessIsActive() {
      return request.time < timestamp.date(2026, 7, 20);
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    match /uploads/{fileId}/{fileName} {
      // Deliberately no file-size or content-type restriction: the Files page
      // accepts every file supported by Firebase Storage.
      allow read: if temporaryAccessIsActive();
      allow create: if temporaryAccessIsActive()
        && request.resource != null
        && request.resource.size > 0;
      allow delete: if temporaryAccessIsActive();
      allow update: if false;
    }

    match /dashboard-source/{clientId}/{uploadId}/{fileName} {
      allow read: if temporaryAccessIsActive();
      allow create: if temporaryAccessIsActive() && isAdmin()
        && request.resource != null
        && request.resource.size > 0
        && request.resource.size <= 250 * 1024 * 1024
        && request.resource.metadata.clientId == clientId
        && request.resource.metadata.dashboardType in ['inventory', 'sales'];
      allow delete: if temporaryAccessIsActive();
      allow update: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
